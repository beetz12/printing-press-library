{
  "manifest_version": "0.3",
  "name": "ap2-pp-mcp",
  "display_name": "AP2",
  "version": "0.1.0",
  "description": "A Go CLI for the AP2 (Agent Payments Protocol) — sign AP2 FinalizationEnvelopes from ucp-pp-cli and authorize payments with merchant MCP endpoints.",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
  "server": {
    "type": "binary",
    "entry_point": "bin/ap2-pp-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/ap2-pp-mcp",
      "args": [],
      "env": [
        {
          "name": "AP2_BASE_URL",
          "description": "Merchant PSP base URL override (default uses the resolved manifest endpoint)",
          "required": false,
          "sensitive": false
        },
        {
          "name": "AP2_CONFIG",
          "description": "Path to ap2-pp-cli config file (default: ~/.config/ap2-pp-cli/config.toml)",
          "required": false,
          "sensitive": false
        },
        {
          "name": "AP2_GPAY_TOKEN",
          "description": "Google Pay payment token for payment authorize --live",
          "required": false,
          "sensitive": true
        },
        {
          "name": "AP2_KEYS_DIR",
          "description": "Directory for ECDSA-P256 keypairs (default: ~/.config/ap2-pp-cli/keys/)",
          "required": false,
          "sensitive": false
        },
        {
          "name": "AP2_TXN_DIR",
          "description": "Directory for transaction record storage (default: ~/.config/ap2-pp-cli/transactions/)",
          "required": false,
          "sensitive": false
        }
      ]
    }
  },
  "user_config": {},
  "mcp_tool_count": 10,
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  }
}
