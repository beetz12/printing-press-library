{
  "manifest_version": "0.3",
  "name": "digg-ai-pp-mcp",
  "display_name": "Digg Ai",
  "version": "4.2.1",
  "description": "Digg AI news curation CLI — track what researchers boost on X, pivot the feed by endorser, see velocity over time.",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
  "server": {
    "type": "binary",
    "entry_point": "bin/digg-ai-pp-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/digg-ai-pp-mcp",
      "args": []
    }
  },
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  }
}
